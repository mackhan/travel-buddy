/* pages/publish/publish.wxss */

.page-publish {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 160rpx;
}

.publish-header {
  background: linear-gradient(165deg, #12B7B5 0%, #0E9D9B 100%);
  padding: 40rpx 32rpx 48rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.publish-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.publish-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单 */
.form-section {
  padding: 24rpx 32rpx;
  margin-top: -20rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-label {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.form-input {
  width: 100%;
  height: 48rpx;
  font-size: 30rpx;
  color: #1A1A2E;
  border-bottom: 2rpx solid #F0F0F0;
  padding-bottom: 12rpx;
}

/* 目的地选择 */
.dest-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0 12rpx;
  font-size: 30rpx;
  color: #1A1A2E;
  border-bottom: 2rpx solid #F0F0F0;
}

.dest-select.empty {
  color: #BBBBBB;
}

.dest-arrow {
  font-size: 32rpx;
  color: #CCC;
  margin-left: 12rpx;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 28rpx;
  color: #1A1A2E;
  line-height: 1.8;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 8rpx;
}

/* 日期选择器 */
.date-pickers {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-picker-box {
  flex: 1;
  background: #F5F7FA;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1A1A2E;
  text-align: center;
}

.date-picker-box.empty {
  color: #BBBBBB;
}

.date-sep {
  font-size: 26rpx;
  color: #999999;
}

/* 提交 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B2B 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  padding: 26rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 140, 66, 0.35);
  transition: all 0.2s ease;
}

.submit-btn:active {
  transform: scale(0.97);
}

.submit-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}
