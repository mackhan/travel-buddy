<!-- pages/publish/publish.wxml -->
<view class="page-publish">
  <view class="publish-header">
    <text class="publish-title">发布你的旅行计划</text>
    <text class="publish-subtitle">让同行的人看到你 🌟</text>
  </view>

  <!-- 表单 -->
  <view class="form-section">
    <!-- 行程标题 -->
    <view class="form-card">
      <view class="form-label">
        <text class="label-icon">📝</text>
        <text>行程标题</text>
      </view>
      <input class="form-input" placeholder="给你的行程起个名字" value="{{title}}" bindinput="onInput" data-field="title" maxlength="30" />
    </view>

    <!-- 目的地 -->
    <view class="form-card">
      <view class="form-label">
        <text class="label-icon">📍</text>
        <text>目的地</text>
      </view>
      <view class="dest-select {{destination ? '' : 'empty'}}" bindtap="openCityPicker">
        <text>{{destination || '点击选择目的地'}}</text>
        <text class="dest-arrow">›</text>
      </view>
    </view>

    <!-- 日期 -->
    <view class="form-card">
      <view class="form-label">
        <text class="label-icon">📅</text>
        <text>出行时间</text>
      </view>
      <view class="date-pickers">
        <picker mode="date" value="{{startDate}}" start="{{today}}" bindchange="onStartDate">
          <view class="date-picker-box {{startDate ? '' : 'empty'}}">
            {{startDate || '出发日期'}}
          </view>
        </picker>
        <text class="date-sep">至</text>
        <picker mode="date" value="{{endDate}}" start="{{startDate || today}}" bindchange="onEndDate">
          <view class="date-picker-box {{endDate ? '' : 'empty'}}">
            {{endDate || '返回日期'}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 标签 -->
    <view class="form-card">
      <view class="form-label">
        <text class="label-icon">🏷️</text>
        <text>搭伴类型（可多选）</text>
      </view>
      <tag-selector value="{{tags}}" bind:change="onTagChange" />
    </view>

    <!-- 描述 -->
    <view class="form-card">
      <view class="form-label">
        <text class="label-icon">✏️</text>
        <text>行程描述</text>
      </view>
      <textarea
        class="form-textarea"
        placeholder="描述一下你的旅行计划、期望搭子的类型..."
        value="{{description}}"
        bindinput="onInput"
        data-field="description"
        maxlength="500"
      />
      <view class="char-count">{{description.length || 0}}/500</view>
    </view>

    <!-- 招募人数 -->
    <view class="form-card">
      <view class="form-label">
        <text class="label-icon">👥</text>
        <text>招募人数（选填）</text>
      </view>
      <input class="form-input" type="number" placeholder="不填则不限人数" value="{{maxMembers}}" bindinput="onInput" data-field="maxMembers" />
    </view>
  </view>

  <!-- 提交 -->
  <view class="submit-area safe-bottom">
    <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="onSubmit">
      <text>🚀 发布行程</text>
    </view>
  </view>

  <!-- 城市选择器 -->
  <city-picker
    visible="{{showCityPicker}}"
    value="{{destination}}"
    bind:select="onCitySelect"
    bind:close="closeCityPicker"
  />
</view>
