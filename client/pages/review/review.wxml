<!-- pages/review/review.wxml -->
<view class="page-review">
  <view class="review-card">
    <view class="review-title">评价 {{toNickname}}</view>
    <view class="review-subtitle">诚实的评价帮助大家找到更好的旅行搭子</view>

    <!-- 星级评分 -->
    <view class="star-section">
      <view class="star-label">总体评价</view>
      <view class="star-row">
        <view
          class="star {{score >= item ? 'star-active' : 'star-empty'}}"
          wx:for="{{stars}}"
          wx:key="*this"
          bindtap="selectStar"
          data-score="{{item}}"
        >★</view>
      </view>
      <view class="score-desc">
        <text wx:if="{{score === 0}}">请点击星星评分</text>
        <text wx:elif="{{score === 1}}">😕 差（1分）</text>
        <text wx:elif="{{score === 2}}">😐 一般（2分）</text>
        <text wx:elif="{{score === 3}}">🙂 还可以（3分）</text>
        <text wx:elif="{{score === 4}}">😊 不错（4分）</text>
        <text wx:elif="{{score === 5}}">🤩 非常好（5分）</text>
      </view>
    </view>

    <!-- 文字评价 -->
    <view class="text-section">
      <view class="text-label">文字评价（选填）</view>
      <textarea
        class="review-textarea"
        placeholder="分享你们的旅途故事，或者一些小建议..."
        maxlength="200"
        bindinput="onInput"
        value="{{content}}"
        auto-height
      />
      <view class="word-count">{{content.length}}/200</view>
    </view>

    <!-- 提交 -->
    <view
      class="submit-btn {{score > 0 && !submitting ? 'submit-active' : 'submit-disabled'}}"
      bindtap="submit"
    >
      <text wx:if="{{!submitting}}">提交评价</text>
      <text wx:else>提交中...</text>
    </view>
  </view>
</view>
