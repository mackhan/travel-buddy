/* pages/review/review.wxss */

.page-review {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 32rpx;
}

.review-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.review-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A2E;
  text-align: center;
  margin-bottom: 12rpx;
}

.review-subtitle {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 48rpx;
}

/* 星级 */
.star-section {
  margin-bottom: 40rpx;
}

.star-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.star-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.star {
  font-size: 72rpx;
  transition: all 0.15s ease;
}

.star-active {
  color: #FAAD14;
  transform: scale(1.1);
}

.star-empty {
  color: #E0E0E0;
}

.score-desc {
  text-align: center;
  font-size: 26rpx;
  color: #666;
  min-height: 40rpx;
}

/* 文字评价 */
.text-section {
  margin-bottom: 48rpx;
}

.text-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.review-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  box-sizing: border-box;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.submit-btn:active {
  transform: scale(0.97);
}

.submit-active {
  background: linear-gradient(135deg, #12B7B5 0%, #0E9D9B 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(18, 183, 181, 0.35);
}

.submit-disabled {
  background: #E0E0E0;
  color: #BBBBBB;
}
