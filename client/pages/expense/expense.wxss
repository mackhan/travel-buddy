/* pages/expense/expense.wxss */

.page-expense {
  min-height: 100vh;
  background: #F5F7FA;
}

.expense-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
}

.expense-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.new-btn {
  background: linear-gradient(135deg, #12B7B5 0%, #0E9D9B 100%);
  color: #FFFFFF;
  padding: 12rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 列表 */
.expense-list {
  padding: 24rpx 32rpx;
}

.expense-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.expense-card:active {
  transform: scale(0.985);
}

.expense-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.expense-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.expense-amount {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #FF8C42;
  margin-top: 4rpx;
}

.expense-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
}

.status-pending {
  background: #FFF7E6;
  color: #FAAD14;
}

.status-done {
  background: #F6FFED;
  color: #52C41A;
}

.expense-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.expense-meta {
  font-size: 24rpx;
  color: #999999;
}

.expense-time {
  font-size: 22rpx;
  color: #CCCCCC;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #12B7B5, #52C41A);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 空状态 */
.empty-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #12B7B5 0%, #0E9D9B 100%);
  color: #FFFFFF;
  padding: 16rpx 48rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 80%;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 40rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
  text-align: center;
  margin-bottom: 36rpx;
}

.modal-field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.field-input {
  width: 100%;
  height: 48rpx;
  font-size: 30rpx;
  color: #1A1A2E;
  border-bottom: 2rpx solid #F0F0F0;
  padding-bottom: 12rpx;
}

.split-modes {
  display: flex;
  gap: 16rpx;
}

.split-mode {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666666;
  background: #F5F7FA;
  transition: all 0.2s ease;
}

.split-active {
  background: #E8F8F7;
  color: #12B7B5;
  font-weight: 600;
  border: 2rpx solid #12B7B5;
}

.modal-preview {
  text-align: center;
  padding: 20rpx;
  background: #E8F8F7;
  border-radius: 16rpx;
  margin-bottom: 28rpx;
}

.preview-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #12B7B5;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 22rpx 0;
  text-align: center;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-cancel {
  background: #F5F7FA;
  color: #999999;
}

.modal-confirm {
  background: linear-gradient(135deg, #12B7B5 0%, #0E9D9B 100%);
  color: #FFFFFF;
}
