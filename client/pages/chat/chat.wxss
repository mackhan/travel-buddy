/* pages/chat/chat.wxss */

.page-chat {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F7FA;
}

/* 消息滚动区 */
.chat-scroll {
  flex: 1;
  overflow: hidden;
}

.chat-messages {
  padding: 20rpx 24rpx;
  padding-bottom: 20rpx;
}

.load-earlier {
  text-align: center;
  padding: 20rpx;
  color: #12B7B5;
  font-size: 24rpx;
}

/* 时间戳分隔 */
.msg-time-divider {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 8rpx;
}

.msg-time-text {
  font-size: 22rpx;
  color: #B0B0B0;
  background: rgba(0, 0, 0, 0.04);
  padding: 4rpx 20rpx;
  border-radius: 16rpx;
}

/* 消息项 */
.msg-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.msg-other {
  flex-direction: row;
}

.msg-mine {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.msg-bubble {
  max-width: 65%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  margin: 0 16rpx;
  word-break: break-all;
}

.msg-other .msg-bubble {
  background: #FFFFFF;
  border-top-left-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.msg-mine .msg-bubble {
  background: linear-gradient(135deg, #12B7B5 0%, #0E9D9B 100%);
  border-top-right-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(18, 183, 181, 0.2);
}

.msg-text {
  font-size: 30rpx;
  line-height: 1.6;
}

.msg-other .msg-text {
  color: #1A1A2E;
}

.msg-mine .msg-text {
  color: #FFFFFF;
}

/* 正在输入 */
.typing-indicator {
  padding: 12rpx 0 12rpx 88rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
  gap: 16rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #F5F7FA;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1A1A2E;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E0E0E0;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.send-btn-active {
  background: linear-gradient(135deg, #12B7B5 0%, #0E9D9B 100%);
  box-shadow: 0 4rpx 16rpx rgba(18, 183, 181, 0.3);
}

.send-btn:active {
  transform: scale(0.95);
}

/* 系统消息：行程卡片 */
.system-card-wrap {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.system-trip-card {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border: 1rpx solid #E8F8F7;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  max-width: 80%;
  box-shadow: 0 4rpx 20rpx rgba(18, 183, 181, 0.1);
}

.system-card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.system-card-body {
  flex: 1;
}

.system-card-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.system-card-link {
  font-size: 24rpx;
  color: #12B7B5;
  font-weight: 600;
}

/* 系统消息：纯文字通知 */
.system-notify-wrap {
  display: flex;
  justify-content: center;
  padding: 12rpx 24rpx;
  margin-bottom: 12rpx;
}

.system-notify-text {
  font-size: 23rpx;
  color: #AAAAAA;
  background: rgba(0, 0, 0, 0.04);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  text-align: center;
  line-height: 1.6;
  max-width: 85%;
}
