<!-- pages/messages/messages.wxml -->
<view class="page-messages">
  <view class="msg-header">
    <text class="msg-title">消息</text>
  </view>

  <!-- 对话列表 -->
  <view class="conversation-list">
    <view
      class="conv-item"
      wx:for="{{conversations}}"
      wx:key="conversationId"
      bindtap="openChat"
      data-conv="{{item}}"
    >
      <view class="conv-avatar-wrap">
        <image class="conv-avatar" src="{{item.otherUser.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="unread-badge" wx:if="{{item.unreadCount > 0}}">
          {{item.unreadCount > 99 ? '99+' : item.unreadCount}}
        </view>
      </view>
      <view class="conv-info">
        <view class="conv-top">
          <text class="conv-name">{{item.otherUser.nickname}}</text>
          <text class="conv-time">{{item.timeText}}</text>
        </view>
        <view class="conv-bottom">
          <text class="conv-preview">{{item.lastMessage.content || ''}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{conversations.length === 0 && !loading}}">
    <text class="empty-icon">💬</text>
    <text class="empty-text">还没有消息</text>
    <text class="empty-hint">在首页找到感兴趣的搭子，发起私信吧</text>
  </view>
</view>
