<!-- pages/profile/profile.wxml -->
<view class="page-profile">

  <!-- 未登录状态 -->
  <view class="not-login-card" wx:if="{{!isLoggedIn}}">
    <image class="not-login-avatar" src="/assets/default-avatar.png" mode="aspectFill" />
    <view class="not-login-text">你还未登录</view>
    <view class="not-login-sub">登录后查看个人信息和行程记录</view>
    <view class="not-login-btn" bindtap="doLogin">微信一键登录</view>
  </view>

  <!-- 已登录状态 -->
  <block wx:if="{{isLoggedIn}}">
  <!-- 个人信息卡 -->
  <view class="profile-hero">
    <view class="hero-bg-gradient"></view>
    <view class="profile-card">
      <!-- 头像 -->
      <view class="avatar-wrap" bindtap="{{isOtherUser ? '' : 'chooseAvatar'}}">
        <image class="profile-avatar" src="{{userInfo.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="avatar-edit-badge" wx:if="{{!isOtherUser}}">📷</view>
      </view>
      <!-- 昵称 -->
      <view class="profile-name" bindtap="{{isOtherUser ? '' : 'goEditProfile'}}">
        {{userInfo.nickname || '旅行者'}}{{isOtherUser ? '' : ' ✏️'}}
      </view>
      <view class="profile-bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</view>
      <view class="profile-bio profile-bio-hint" bindtap="goEditProfile" wx:elif="{{!isOtherUser}}">点击编辑，添加你的个人介绍</view>

      <!-- 数据统计 -->
      <view class="stats-row">
        <view class="stat-item" bindtap="showCreditInfo">
          <text class="stat-num">{{userInfo.creditScore || '5.0'}}</text>
          <text class="stat-label">信誉分</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="goMyTrips">
          <text class="stat-num">{{userInfo.tripCount || 0}}</text>
          <text class="stat-label">行程</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="goMyReviews">
          <text class="stat-num">{{userInfo.reviewCount || 0}}</text>
          <text class="stat-label">评价</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <!-- 查看他人资料时显示「发消息」 -->
    <view class="menu-card" wx:if="{{isOtherUser}}">
      <view class="menu-item" bindtap="startChat">
        <text class="menu-icon">💬</text>
        <text class="menu-text">发消息</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goMyTrips">
        <text class="menu-icon">🗺️</text>
        <text class="menu-text">TA的行程</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goMyReviews">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">TA的评价</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 自己的菜单 -->
    <block wx:if="{{!isOtherUser}}">
    <view class="menu-card">
      <view class="menu-item" bindtap="goMyTrips">
        <text class="menu-icon">🗺️</text>
        <text class="menu-text">我的行程</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goMyReviews">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">我的评价</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goExpense">
        <text class="menu-icon">💰</text>
        <text class="menu-text">费用分摊</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-card">
      <view class="menu-item" bindtap="goEditProfile">
        <text class="menu-icon">✏️</text>
        <text class="menu-text">编辑资料</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="showAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于旅行搭子</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="doLogout">
        <text class="menu-icon">🚪</text>
        <text class="menu-text">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
  </block>

  <!-- 行程/评价列表（内嵌） -->
  <view class="trip-list-section" wx:if="{{showTrips}}">
    <view class="section-header">
      <text class="section-title">我的行程</text>
      <view class="close-btn" bindtap="hideTrips">关闭</view>
    </view>

    <!-- 状态筛选 -->
    <view class="status-tabs">
      <view class="status-tab {{tripStatus === '' ? 'tab-active' : ''}}" bindtap="filterTrips" data-status="">全部</view>
      <view class="status-tab {{tripStatus === 'active' ? 'tab-active' : ''}}" bindtap="filterTrips" data-status="active">进行中</view>
      <view class="status-tab {{tripStatus === 'completed' ? 'tab-active' : ''}}" bindtap="filterTrips" data-status="completed">已完成</view>
      <view class="status-tab {{tripStatus === 'cancelled' ? 'tab-active' : ''}}" bindtap="filterTrips" data-status="cancelled">已取消</view>
    </view>

    <view class="my-trip-item" wx:for="{{myTrips}}" wx:key="id" bindtap="viewTrip" data-id="{{item.id || item._id}}">
      <view class="my-trip-top">
        <text class="my-trip-dest">📍 {{item.destination}}</text>
        <view class="my-trip-status status-{{item.status}}">
          {{item.status === 'active' ? '进行中' : item.status === 'completed' ? '已完成' : '已取消'}}
        </view>
      </view>
      <view class="my-trip-dates">📅 {{item.startDateText}} — {{item.endDateText}}</view>
      <view class="my-trip-tags">
        <text class="my-trip-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{myTrips.length === 0}}">
      <text class="empty-icon">🗺️</text>
      <text class="empty-text">还没有行程</text>
    </view>
  </view>

  <!-- 我的评价列表 -->
  <view class="review-list-section" wx:if="{{showReviews}}">
    <view class="section-header">
      <text class="section-title">收到的评价</text>
      <view class="close-btn" bindtap="hideReviews">关闭</view>
    </view>

    <view class="review-item" wx:for="{{myReviews}}" wx:key="_id">
      <view class="review-top">
        <image class="review-avatar" src="{{item.fromUserId.avatar}}" mode="aspectFill" />
        <view class="review-info">
          <text class="review-name">{{item.fromUserId.nickname}}</text>
          <view class="review-stars">
            <text class="star-on" wx:for="{{item.starArr}}" wx:for-item="s" wx:key="index">★</text>
          </view>
        </view>
        <text class="review-time">{{item.timeText}}</text>
      </view>
      <view class="review-content" wx:if="{{item.content}}">{{item.content}}</view>
      <view class="review-trip" wx:if="{{item.tripId}}">
        行程：{{item.tripId.destination}}
      </view>
    </view>

    <view class="empty-state" wx:if="{{myReviews.length === 0}}">
      <text class="empty-icon">⭐</text>
      <text class="empty-text">还没有收到评价</text>
    </view>
  </view>

  <!-- 编辑资料弹窗 -->
  <view class="modal-mask" wx:if="{{showEditBio}}" catchtap="cancelEditBio">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">编辑资料</view>
      <view class="modal-field">
        <view class="modal-label">昵称</view>
        <input class="modal-input" placeholder="输入昵称" value="{{editNickname}}" bindinput="onNicknameInput" maxlength="20" />
      </view>
      <view class="modal-field">
        <view class="modal-label">个人介绍</view>
        <textarea
          class="bio-textarea"
          placeholder="介绍一下自己..."
          value="{{editBioValue}}"
          bindinput="onBioInput"
          maxlength="200"
        />
        <view class="char-count">{{editBioValue.length || 0}}/200</view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-cancel" bindtap="cancelEditBio">取消</view>
        <view class="modal-btn modal-confirm" bindtap="confirmEditBio">保存</view>
      </view>
    </view>
  </view>
  </block>
</view>
