<!-- pages/detail/detail.wxml -->
<view class="page-detail" wx:if="{{trip}}">
  <!-- 顶部信息卡 -->
  <view class="detail-hero">
    <view class="hero-gradient"></view>
    <view class="hero-content">
      <view class="trip-title" wx:if="{{trip.title}}">{{trip.title}}</view>
      <view class="dest-row">
        <text class="dest-icon">📍</text>
        <text class="dest-name">{{trip.destination}}</text>
      </view>
      <view class="date-row">
        <text class="date-icon">📅</text>
        <text class="date-range">{{startDateText}} — {{endDateText}}</text>
        <view class="days-badge">{{days}}天</view>
      </view>
      <view class="member-row" wx:if="{{trip.maxMembers > 0}}">
        <text class="member-icon">👥</text>
        <text class="member-text">{{trip.currentMembers || 1}} / {{trip.maxMembers}} 人</text>
        <view class="full-badge" wx:if="{{trip.maxMembers > 0 && trip.currentMembers >= trip.maxMembers}}">已满员</view>
      </view>
    </view>
  </view>

  <!-- 标签 -->
  <view class="section tags-section">
    <view class="tag-chip" wx:for="{{trip.tags}}" wx:key="*this">
      <text>{{tagIcons[item]}} {{item}}</text>
    </view>
  </view>

  <!-- 发布者信息 -->
  <view class="section user-section" bindtap="viewProfile">
    <image class="user-avatar" src="{{trip.user.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <view class="user-name">{{trip.user.nickname || '旅行者'}}</view>
      <view class="user-meta">
        <view class="credit-stars">
          <text class="star-on" wx:for="{{fullStars}}" wx:key="index">★</text>
          <text class="star-off" wx:for="{{emptyStars}}" wx:key="index">★</text>
          <text class="credit-num">{{trip.user.creditScore || '5.0'}}</text>
        </view>
        <text class="review-count">{{trip.user.reviewCount || 0}}条评价</text>
      </view>
    </view>
    <view class="arrow-icon">›</view>
  </view>

  <!-- 行程描述 -->
  <view class="section desc-section" wx:if="{{trip.description}}">
    <view class="section-title">行程描述</view>
    <view class="desc-content">{{trip.description}}</view>
  </view>

  <!-- 已加入的成员列表 -->
  <view class="section members-section" wx:if="{{members.length > 0}}">
    <view class="section-title">同行搭子（{{members.length}}人）</view>
    <view class="members-list">
      <view
        class="member-item"
        wx:for="{{members}}"
        wx:key="id"
        bindtap="viewMemberProfile"
        data-user-id="{{item.user.id}}"
      >
        <image class="member-avatar" src="{{item.user.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="member-name">{{item.user.nickname}}</view>
        <!-- 行程完成后，非行程主且是已加入成员，可以评价行程主 -->
        <view
          class="review-btn-small"
          wx:if="{{trip.status === 'completed' && !isOwner}}"
          catchtap="goReviewOwner"
        >评价</view>
      </view>
    </view>
  </view>

  <!-- 待审批申请列表（仅行程主可见） -->
  <view class="section applicants-section" wx:if="{{isOwner && applicants.length > 0}}">
    <view class="section-title">申请同行（{{applicants.length}}人待确认）</view>
    <view class="applicant-item" wx:for="{{applicants}}" wx:key="id">
      <image
        class="applicant-avatar"
        src="{{item.user.avatar || '/assets/default-avatar.png'}}"
        mode="aspectFill"
        bindtap="viewMemberProfile"
        data-user-id="{{item.user.id}}"
      />
      <view class="applicant-info">
        <view class="applicant-name">{{item.user.nickname}}</view>
        <view class="applicant-score">
          <text class="star-on">★</text>
          <text class="score-num">{{item.user.creditScore || '5.0'}}</text>
          <text class="score-cnt">（{{item.user.reviewCount || 0}}条评价）</text>
        </view>
      </view>
      <view class="applicant-actions">
        <view
          class="action-approve"
          catchtap="approveApplicant"
          data-user-id="{{item.user.id}}"
          data-nickname="{{item.user.nickname}}"
        >同意</view>
        <view
          class="action-reject"
          catchtap="rejectApplicant"
          data-user-id="{{item.user.id}}"
          data-nickname="{{item.user.nickname}}"
        >拒绝</view>
      </view>
    </view>
  </view>

  <!-- 行程完成后：行程主评价搭子们 -->
  <view class="section review-section" wx:if="{{isOwner && trip.status === 'completed' && members.length > 0}}">
    <view class="section-title">去评价你的搭子们</view>
    <view class="review-member-item" wx:for="{{members}}" wx:key="id">
      <image class="member-avatar" src="{{item.user.avatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
      <view class="member-name flex-1">{{item.user.nickname}}</view>
      <view
        class="review-btn"
        catchtap="goReview"
        data-user-id="{{item.user.id}}"
        data-nickname="{{item.user.nickname}}"
      >写评价 ★</view>
    </view>
  </view>

  <!-- 底部操作：非行程主 -->
  <view class="action-bar safe-bottom" wx:if="{{!isOwner && trip.status === 'active'}}">
    <!-- 已满员 -->
    <view class="action-btn join-btn join-disabled" wx:if="{{trip.maxMembers > 0 && trip.currentMembers >= trip.maxMembers}}">
      <text>😅 行程已满员</text>
    </view>
    <!-- 待审批 -->
    <view class="action-btn join-btn join-pending" wx:elif="{{trip.myMemberStatus === 'pending'}}">
      <text>⏳ 申请中...</text>
    </view>
    <!-- 已加入 -->
    <view class="action-btn join-btn join-joined" wx:elif="{{trip.myMemberStatus === 'approved'}}">
      <text>✅ 已加入</text>
    </view>
    <!-- 可以申请 -->
    <view class="action-btn join-btn" wx:else bindtap="joinTrip">
      <text>🙋 申请同行</text>
    </view>
    <view class="action-btn chat-btn" bindtap="startChat">
      <text>💬 私信</text>
    </view>
  </view>

  <!-- 底部操作：自己的行程 -->
  <view class="action-bar safe-bottom" wx:if="{{isOwner}}">
    <view class="action-btn cancel-btn" bindtap="cancelTrip" wx:if="{{trip.status === 'active'}}">
      <text>取消行程</text>
    </view>
    <view class="action-btn complete-btn" bindtap="completeTrip" wx:if="{{trip.status === 'active'}}">
      <text>✅ 标记完成</text>
    </view>
    <!-- 已完成/已取消：可以再发一次 -->
    <view class="action-btn republish-btn" bindtap="republishTrip" wx:if="{{trip.status !== 'active'}}">
      <text>🔄 再发一次</text>
    </view>
  </view>
</view>

<!-- 加载中 -->
<view class="loading-page" wx:if="{{loading}}">
  <view class="loading-dots">
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
  </view>
</view>
