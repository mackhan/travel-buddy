/* pages/detail/detail.wxss */

.page-detail {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 140rpx;
}

/* 顶部英雄区 */
.detail-hero {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
}

.hero-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(165deg, #12B7B5 0%, #0E9D9B 50%, #0A8A88 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.trip-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.dest-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.dest-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.dest-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.date-row {
  display: flex;
  align-items: center;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.date-range {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.days-badge {
  margin-left: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.member-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.member-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.member-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 通用 section */
.section {
  margin: 20rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 16rpx;
}

/* 标签 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: -16rpx;
}

.tag-chip {
  background: #E8F8F7;
  color: #12B7B5;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

/* 用户卡片 */
.user-section {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #E8F8F7;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 20rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.credit-stars {
  display: flex;
  align-items: center;
}

.star-on {
  font-size: 24rpx;
  color: #FAAD14;
}

.star-off {
  font-size: 24rpx;
  color: #E0E0E0;
}

.credit-num {
  font-size: 24rpx;
  color: #FAAD14;
  margin-left: 6rpx;
  font-weight: 500;
}

.review-count {
  font-size: 24rpx;
  color: #999999;
}

.arrow-icon {
  font-size: 40rpx;
  color: #CCCCCC;
}

/* 描述 */
.desc-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.97);
}

.chat-btn {
  background: linear-gradient(135deg, #12B7B5 0%, #0E9D9B 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(18, 183, 181, 0.3);
}

.join-btn {
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B2B 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.3);
}

.cancel-btn {
  background: #F5F7FA;
  color: #999999;
}

.complete-btn {
  background: linear-gradient(135deg, #52C41A 0%, #43A814 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
}

/* 加载 */
.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}
