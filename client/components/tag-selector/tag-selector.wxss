/* components/tag-selector/tag-selector.wxss */

.tag-selector {
  width: 100%;
}

.tag-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  margin-bottom: 16rpx;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: calc((100% - 64rpx) / 5);
  min-width: 120rpx;
  padding: 20rpx 8rpx;
  border-radius: 20rpx;
  background: #F5F7FA;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.tag-btn:active {
  transform: scale(0.95);
}

.tag-btn-active {
  background: #E8F8F7;
  border-color: #12B7B5;
  box-shadow: 0 4rpx 16rpx rgba(18, 183, 181, 0.2);
}

.tag-btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tag-btn-label {
  font-size: 24rpx;
  color: #666666;
}

.tag-btn-active .tag-btn-label {
  color: #12B7B5;
  font-weight: 500;
}
