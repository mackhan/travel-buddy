.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #F5F5F5 100%);
  padding-bottom: 140rpx;
}

.header {
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.user-location {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.user-status {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.3);
}

.content-section {
  padding: 30rpx;
}

.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.card-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  display: block;
  margin-bottom: 30rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.tags-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tags-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 600;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.tag-primary {
  background: rgba(255, 107, 157, 0.1);
  color: #FF6B9D;
}

.message-input-wrapper {
  position: relative;
}

.message-input {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.input-placeholder {
  color: #CCCCCC;
}

.char-count {
  font-size: 22rpx;
  color: #CCCCCC;
  text-align: right;
  display: block;
  margin-top: 12rpx;
}

.tips-card {
  background: rgba(255, 107, 157, 0.08);
  border-radius: 20rpx;
  padding: 30rpx;
  border: 2rpx dashed rgba(255, 107, 157, 0.3);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B9D;
  display: block;
  margin-bottom: 16rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.8;
  display: block;
  margin-bottom: 8rpx;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
}

.action-btn.secondary {
  background: #FFFFFF;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
}

.action-btn::after {
  border: none;
}